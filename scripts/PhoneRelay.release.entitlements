<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Release builds should not weaken the hardened runtime with dynamic-loader
      exceptions. The app launches adb/scrcpy helpers as signed executables,
      which does not require DYLD environment variables or disabled library
      validation in the main app process.
    -->
    <!-- App Sandbox is required for the production app and for inherited helper entitlements. -->
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <!-- adb connects to Android devices over Wi-Fi and uses local sockets. -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- USB debugging is used to authorize phones and prepare Wi-Fi handoff. -->
    <key>com.apple.security.device.usb</key>
    <true/>
    <!-- User-selected captures plus the default Downloads location. -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!-- adb needs Android debug keys for both USB and Wi-Fi authenticated targets. -->
    <key>com.apple.security.temporary-exception.files.home-relative-path.read-write</key>
    <array>
        <string>.android/</string>
    </array>
    <!-- Sparkle installer status/connection services for sandboxed updates. -->
    <key>com.apple.security.temporary-exception.mach-lookup.global-name</key>
    <array>
        <string>com.mallenkb.PhoneRelay-spks</string>
        <string>com.mallenkb.PhoneRelay-spki</string>
    </array>
    <!--
      Communication Notifications: forwarded banners present the source app icon
      as the large left avatar with Phone Relay auto-badged in the corner (the
      iPhone-Mirroring look). RESTRICTED: only honored when authorized by a
      provisioning profile from a paid Apple Developer account with the
      "Communication Notifications" capability on the App ID. Without that, the
      code falls back to the attachment thumbnail.
    -->
    <key>com.apple.developer.usernotifications.communication</key>
    <true/>
</dict>
</plist>
