<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Release builds should not weaken the hardened runtime with dynamic-loader
      exceptions. The app launches adb/scrcpy helpers as signed executables,
      which does not require DYLD environment variables or disabled library
      validation in the main app process.
    -->
    <!--
      NOT sandboxed, on purpose. The App Sandbox breaks the adb stack on this
      app: it routes the bundled adb's HOME to the container (foreign adb keys),
      and gates the LAN sweep + `adb connect <ip>:5555` behind Local Network
      privacy, which kills Wi-Fi handoff / adb-over-Wi-Fi. The script/notarize
      pipeline must stay unsandboxed (notarize.sh fails the build if app-sandbox
      reappears). See the app-sandbox-breaks-adb-stack project note.
    -->
    <!--
      Communication Notifications: forwarded banners present the source app icon
      as the large left avatar with Phone Relay auto-badged in the corner (the
      iPhone-Mirroring look). RESTRICTED: only honored when authorized by a
      provisioning profile from a paid Apple Developer account with the
      "Communication Notifications" capability on the App ID. Without that, the
      code falls back to the attachment thumbnail.
    -->
    <key>com.apple.developer.usernotifications.communication</key>
    <true/>
</dict>
</plist>
