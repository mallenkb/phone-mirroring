<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Not sandboxed: the app spawns adb/scrcpy helpers and talks to the device
      over the local network, which the App Sandbox would block. These two
      hardened-runtime exceptions let the signed app launch the bundled adb
      (which may carry a different signing identity) and honor the adb-path
      override env var used in development.
    -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <!--
      Communication Notifications: forwarded banners present the source app icon
      as the large left avatar with PhoneRelay auto-badged in the corner (the
      iPhone-Mirroring look). RESTRICTED: only honored when authorized by a
      provisioning profile from a paid Apple Developer account with the
      "Communication Notifications" capability on the App ID — and the script
      pipeline must also pass `--entitlements` to codesign (it currently does
      not). Without those, the code falls back to the attachment thumbnail.
    -->
    <key>com.apple.developer.usernotifications.communication</key>
    <true/>
</dict>
</plist>
